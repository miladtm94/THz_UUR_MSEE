# MATLAB-specific ignores
*.asv          # Autosave files
*.m~           # Backup files
*.mex*         # Compiled MEX binaries
*.mexa64
*.mexmaci64
*.mexw64

# Simulation output files (generated by main.m and run_figure_*.m)
results/*.mat
figures/*.fig
figures/*.png
figures/*.pdf
figures/*.eps

# Temporary files
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# CVX solver cache (if any)
cvx_cache/

# MATLAB preferences
*.mlx.bak
